    "@openstarry-plugin/standard-function-stdio": "workspace:*",
    "@openstarry-plugin/standard-function-skill": "workspace:*",
    "@openstarry-plugin/guide-character-init": "workspace:*",
    "@openstarry-plugin/transport-websocket": "workspace:*",
    "@openstarry-plugin/transport-http": "workspace:*",
    "@openstarry-plugin/web-ui": "workspace:*",
    "@openstarry-plugin/http-static": "workspace:*",
    "@openstarry-plugin/tui-dashboard": "workspace:*",
    "@openstarry-plugin/devtools": "workspace:*",
    "@openstarry-plugin/workflow-engine": "workspace:*",
    "@openstarry-plugin/mcp-server": "workspace:*",
    "@openstarry-plugin/mcp-client": "workspace:*",
    "@openstarry-plugin/mcp-common": "workspace:*",
    "@openstarry-plugin/provider-gemini": "workspace:*",
    "@openstarry-plugin/provider-claude": "workspace:*",
    "@openstarry-plugin/provider-chatgpt": "workspace:*",
    "@openstarry-plugin/provider-chatgpt-oauth": "workspace:*",
    "@openstarry-plugin/provider-local-llama": "workspace:*",
