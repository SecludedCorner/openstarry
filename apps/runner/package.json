    "@openstarry-plugin/context-summary": "workspace:*",
    "@openstarry-plugin/distributed-alaya": "workspace:*",
    "@openstarry-plugin/guide-persistent": "workspace:*",
    "@openstarry-plugin/spc-monitor": "workspace:*",
    "@openstarry-plugin/vedana-sensor-core": "workspace:*",
