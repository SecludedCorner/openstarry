{
  "name": "@openstarry/runner",
  "version": "0.1.0-alpha",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openstarry": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc -b && node -e \"require('fs').cpSync('src/data','dist/data',{recursive:true})\"",
    "clean": "rimraf --glob dist \"*.tsbuildinfo\"",
    "dev": "tsc -b --watch",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:plugin-deps": "node scripts/verify-plugin-deps.mjs"
  },
  "dependencies": {
    "@openstarry/core": "workspace:*",
    "@openstarry/sdk": "workspace:*",
