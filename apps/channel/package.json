{
  "name": "@openstarry/channel",
  "version": "0.1.0-alpha",
  "description": "openstarry-channel — standalone multi-agent communication hub process",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf --glob dist \"*.tsbuildinfo\"",
    "dev": "tsc -b --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openstarry/sdk": "workspace:*",
    "@openstarry/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
